# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_MAX_INPUT_CHARS=1000

# --- SQL Agent Server ---
AGENT_API_HOST=0.0.0.0
AGENT_API_PORT=8080
AGENT_API_TOKEN=
AGENT_API_BASE_URL=http://127.0.0.1:8080
AGENT_TIMEOUT_S=300
ALLOWED_STATEMENT_FAMILIES=SELECT

# --- Claude Code ---
CLAUDE_CODE_BIN=claude
CLAUDE_CODE_PROJECT_DIR=
MCP_CONFIG_PATH=.mcp.json

# --- Metabase ---
METABASE_BASE_URL=
METABASE_USERNAME=
METABASE_PASSWORD=
# Optional: when set, the Schema MCP authenticates with X-API-KEY instead of
# username/password session login.
METABASE_API_KEY=
METABASE_QUERY_TIMEOUT_S=15

# --- Registry ---
REGISTRY_PATH=.claude/skills/sql_add_repo/registry.json

# --- Code Graph (upstream code-review-graph) ---
# Required for `register`: comma-separated absolute directory roots; repo
# paths outside these are refused.
CODE_GRAPH_ALLOWED_ROOTS=

# --- Audit ---
AUDIT_LOG_DIR=var/audit
LOG_LEVEL=INFO
