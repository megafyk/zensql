{
  "permissions": {
    "allow": [
      "Skill(incremental-implementation)",
      "Write",
      "Edit",
      "Bash(uv --version)",
      "Bash(uv python *)",
      "Bash(uv sync *)",
      "Bash(uv run *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows --repo \"/home/myadmin/tools/projects/zensql\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph status --repo \"/home/myadmin/tools/projects/zensql\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
